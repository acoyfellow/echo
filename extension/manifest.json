{
  "manifest_version": 3,
  "name": "echo",
  "version": "0.0.1",
  "description": "Your authenticated browser tab becomes a remote target for an MCP agent. The agent writes a plan; Cloudflare runs it; your tab does the work.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "externally_connectable": {
    "matches": [
      "http://127.0.0.1:*/*",
      "http://localhost:*/*",
      "https://echo.ax.cloudflare.dev/*",
      "https://echo.coey.dev/*"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  }
}
